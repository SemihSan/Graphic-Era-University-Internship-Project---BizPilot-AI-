# BizPilot AI environment variables
# Copy this file to `.env` and fill real values locally.
# Never commit real API keys.

# Main LLM provider: OpenAI API
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.4

# Optional proxy configuration for phone proxy apps such as NetShare
HTTP_PROXY=http://192.168.49.1:8282
HTTPS_PROXY=http://192.168.49.1:8282
NO_PROXY=localhost,127.0.0.1

# LLM runtime settings
LLM_TIMEOUT_SECONDS=30
LLM_MAX_TOKENS=420
LLM_RETRY_ATTEMPTS=1
LLM_RETRY_DELAY_SECONDS=3
LLM_BATCH_DELAY_SECONDS=1.5

# Competitor-intelligence retrieval options for later modules
TAVILY_API_KEY=
SERPAPI_API_KEY=
